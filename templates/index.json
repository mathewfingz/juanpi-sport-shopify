    "hero_slideshow": {
      "type": "slideshow",
      "blocks": {
        "slide_1": {
          "type": "_slide",
          "settings": {
            "slide_background": true,
            "container": "page-width page-width--full",
            "height": "full",
            "media_type_1": "image",
            "inherit_color_scheme": false,
            "scheme_background": "#0A0A0A",
            "scheme_foreground_heading": "#FFFFFF",
            "scheme_foreground": "#FFFFFF",
            "scheme_primary": "#FFFFFF",
            "scheme_primary_hover": "#E0E0E0",
            "scheme_border": "#0A0A0A",
            "scheme_shadow": "#000000"
          },
          "blocks": {
            "hero_heading": {
              "type": "text",
              "settings": {
                "text": "<h1>ENTRENA. CONQUISTA. REPITE.</h1>",
                "type_preset": "rte",
                "highlight_text": false,
                "width": "fit-content"
              }
            },
            "hero_subtitle": {
              "type": "text",
              "settings": {
                "text": "<p>Ropa deportiva de alto rendimiento disenada para mujeres que no se detienen.</p>",
                "type_preset": "rte",
                "width": "fit-content"
              }
            },
            "hero_btn1": {
              "type": "button",
              "settings": {
                "label": "Novedades",
                "link": "shopify:\/\/collections\/all",
                "style_class": "button",
                "button_style": "default"
              }
            },
            "hero_btn2": {
              "type": "button",
              "settings": {
                "label": "Ver Coleccion",
                "link": "shopify:\/\/collections",
                "style_class": "button-secondary",
                "button_style": "outline"
              }
            }
          },
          "block_order": [
            "hero_heading",
            "hero_subtitle",
            "hero_btn1",
            "hero_btn2"
          ]
        },
        "slide_2": {
          "type": "_slide",
          "settings": {
            "slide_background": true,
            "container": "page-width page-width--full",
            "height": "full",
            "media_type_1": "image",
            "inherit_color_scheme": false,
            "scheme_background": "#1A1A2E",
            "scheme_foreground_heading": "#FFFFFF",
            "scheme_foreground": "#FFFFFF",
            "scheme_primary": "#FFD600",
            "scheme_primary_hover": "#FFCA28",
            "scheme_border": "#1A1A2E",
            "scheme_shadow": "#000000"
          },
          "blocks": {
            "slide2_heading": {
              "type": "text",
              "settings": {
                "text": "<h1>NUEVA COLECCION 2026</h1>",
                "type_preset": "rte",
                "highlight_text": true,
                "highlight_text_content": "2026",
                "highlight_text_type": "text",
                "highlight_text_color": "#FFD600",
                "width": "fit-content"
              }
            },
            "slide2_subtitle": {
              "type": "text",
              "settings": {
                "text": "<p>Soporte, comodidad y estilo en cada movimiento. Descubre lo nuevo.</p>",
                "type_preset": "rte",
                "width": "fit-content"
