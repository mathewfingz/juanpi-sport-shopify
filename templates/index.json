    "bnpl_features": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  .jp-bnpl {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 20px;\n    text-align: center;\n  }\n  .jp-bnpl__title {\n    font-size: 2rem;\n    font-weight: 800;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0 0 50px 0;\n  }\n  .jp-bnpl__grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 30px;\n  }\n  @media (max-width: 749px) {\n    .jp-bnpl__grid {\n      grid-template-columns: repeat(2, 1fr);\n      gap: 24px;\n    }\n  }\n  .jp-bnpl__item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 16px;\n  }\n  .jp-bnpl__icon {\n    width: 56px;\n    height: 56px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: 50%;\n    background-color: #001E4A;\n  }\n  .jp-bnpl__icon svg {\n    width: 26px;\n    height: 26px;\n    fill: #FFD600;\n  }\n  .jp-bnpl__label {\n    font-size: 1rem;\n    font-weight: 700;\n    color: #0A0A0A;\n    text-transform: uppercase;\n  }\n  .jp-bnpl__desc {\n    font-size: 0.85rem;\n    color: #666;\n    line-height: 1.5;\n  }\n</style>\n<div class=\"jp-bnpl\">\n  <h2 class=\"jp-bnpl__title\">COMPRA AHORA, PAGA DESPUÉS</h2>\n  <div class=\"jp-bnpl__grid\">\n    <div class=\"jp-bnpl__item\">\n      <div class=\"jp-bnpl__icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\"><path d=\"M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z\"/></svg></div>\n      <div class=\"jp-bnpl__label\">Tarjetas</div>\n      <div class=\"jp-bnpl__desc\">Crédito y débito</div>\n    </div>\n    <div class=\"jp-bnpl__item\">\n      <div class=\"jp-bnpl__icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\"><path d=\"M19 14V6c0-1.1-.9-2-2-2H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zm-2 0H3V6h14v8zm-7-1c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm13-6v11c0 1.1-.9 2-2 2H4v-2h17V7h2z\"/></svg></div>\n      <div class=\"jp-bnpl__label\">Cuotas</div>\n      <div class=\"jp-bnpl__desc\">Hasta 12 sin interés</div>\n    </div>\n    <div class=\"jp-bnpl__item\">\n      <div class=\"jp-bnpl__icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\"><path d=\"M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10zm-6-3c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z\"/></svg></div>\n      <div class=\"jp-bnpl__label\">Envío Seguro</div>\n      <div class=\"jp-bnpl__desc\">Entrega protegida</div>\n    </div>\n    <div class=\"jp-bnpl__item\">\n      <div class=\"jp-bnpl__icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\"><path d=\"M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z\"/></svg></div>\n      <div class=\"jp-bnpl__label\">Soporte WhatsApp</div>\n      <div class=\"jp-bnpl__desc\">Atención inmediata</div>\n    </div>\n  </div>\n</div>",
        "color_scheme": "scheme-1",
        "padding_top": 60,
        "padding_bottom": 60
      }
    },
    "newsletter_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  .jp-newsletter {\n    background-color: #001E4A;\n    color: #FFFFFF;\n    text-align: center;\n    padding: 70px 20px;\n  }\n  .jp-newsletter__inner {\n    max-width: 600px;\n    margin: 0 auto;\n  }\n  .jp-newsletter__title {\n    font-size: 2.4rem;\n    font-weight: 800;\n    text-transform: uppercase;\n    margin: 0 0 16px 0;\n  }\n  .jp-newsletter__text {\n    font-size: 1rem;\n    line-height: 1.6;\n    opacity: 0.8;\n    margin-bottom: 30px;\n  }\n  .jp-newsletter__form {\n    display: flex;\n    gap: 0;\n    max-width: 480px;\n    margin: 0 auto;\n  }\n  @media (max-width: 749px) {\n    .jp-newsletter__form {\n      flex-direction: column;\n      gap: 12px;\n    }\n  }\n  .jp-newsletter__input {\n    flex: 1;\n    padding: 14px 20px;\n    border: 2px solid rgba(255,255,255,0.2);\n    background: transparent;\n    color: #FFFFFF;\n    font-size: 0.95rem;\n    outline: none;\n    transition: border-color 0.3s;\n  }\n  .jp-newsletter__input::placeholder {\n    color: rgba(255,255,255,0.5);\n  }\n  .jp-newsletter__input:focus {\n    border-color: #FFD600;\n  }\n  .jp-newsletter__btn {\n    background-color: #FFD600;\n    color: #0A0A0A;\n    border: none;\n    padding: 14px 32px;\n    font-size: 0.9rem;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n    cursor: pointer;\n    transition: background-color 0.3s;\n    white-space: nowrap;\n  }\n  .jp-newsletter__btn:hover {\n    background-color: #e6c200;\n  }\n</style>\n<div class=\"jp-newsletter\">\n  <div class=\"jp-newsletter__inner\">\n    <h2 class=\"jp-newsletter__title\">ÚNETE AL MOVIMIENTO</h2>\n    <p class=\"jp-newsletter__text\">Suscríbete y recibe ofertas exclusivas, acceso anticipado a nuevas colecciones y contenido especial para tu entrenamiento.</p>\n    {% form 'customer', id: 'jp-newsletter-form' %}\n      <div class=\"jp-newsletter__form\">\n        <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter\">\n        <input type=\"email\" name=\"contact[email]\" class=\"jp-newsletter__input\" placeholder=\"Tu correo electrónico\" required aria-label=\"Correo electrónico\">\n        <button type=\"submit\" class=\"jp-newsletter__btn\">Suscribirme</button>\n      </div>\n    {% endform %}\n  </div>\n</div>",
        "color_scheme": "scheme-4",
        "padding_top": 0,
        "padding_bottom": 0
      }
    }
  },
