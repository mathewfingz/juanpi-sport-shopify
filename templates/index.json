    "split_banner": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  .jp-split-banner {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    min-height: 500px;\n    overflow: hidden;\n  }\n  @media (max-width: 749px) {\n    .jp-split-banner {\n      grid-template-columns: 1fr;\n    }\n  }\n  .jp-split-banner__content {\n    background-color: #001E4A;\n    color: #FFFFFF;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    padding: 60px 50px;\n  }\n  .jp-split-banner__tag {\n    font-size: 0.85rem;\n    text-transform: uppercase;\n    letter-spacing: 3px;\n    margin-bottom: 16px;\n    opacity: 0.8;\n  }\n  .jp-split-banner__heading {\n    font-size: 2.8rem;\n    font-weight: 800;\n    line-height: 1.1;\n    margin: 0 0 20px 0;\n    text-transform: uppercase;\n  }\n  .jp-split-banner__heading span {\n    color: #FFD600;\n  }\n  .jp-split-banner__text {\n    font-size: 1rem;\n    line-height: 1.6;\n    margin-bottom: 30px;\n    opacity: 0.85;\n    max-width: 420px;\n  }\n  .jp-split-banner__btn {\n    display: inline-block;\n    background-color: #FFD600;\n    color: #0A0A0A;\n    padding: 14px 36px;\n    font-size: 0.9rem;\n    font-weight: 700;\n    text-transform: uppercase;\n    text-decoration: none;\n    letter-spacing: 1px;\n    transition: background-color 0.3s;\n    width: fit-content;\n  }\n  .jp-split-banner__btn:hover {\n    background-color: #e6c200;\n  }\n  .jp-split-banner__image {\n    background-color: #E5E5E5;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    min-height: 400px;\n    position: relative;\n    overflow: hidden;\n  }\n  .jp-split-banner__image svg {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n</style>\n<div class=\"jp-split-banner\">\n  <div class=\"jp-split-banner__content\">\n    <div class=\"jp-split-banner__tag\">Colección Mujer</div>\n    <h2 class=\"jp-split-banner__heading\">CONQUISTA CON<br><span>DISCIPLINA</span></h2>\n    <p class=\"jp-split-banner__text\">Ropa deportiva diseñada para acompañarte en cada entrenamiento. Comodidad, estilo y rendimiento en cada prenda.</p>\n    <a href=\"/collections/all\" class=\"jp-split-banner__btn\">Ver Todo</a>\n  </div>\n  <div class=\"jp-split-banner__image\">\n    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}\n  </div>\n</div>",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "editors_picks": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  .jp-picks {\n    max-width: 1400px;\n    margin: 0 auto;\n    padding: 0 20px;\n  }\n  .jp-picks__header {\n    text-align: center;\n    margin-bottom: 40px;\n  }\n  .jp-picks__tag {\n    font-size: 0.85rem;\n    text-transform: uppercase;\n    letter-spacing: 3px;\n    color: #666;\n    margin-bottom: 12px;\n  }\n  .jp-picks__title {\n    font-size: 2.4rem;\n    font-weight: 800;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0;\n  }\n  .jp-picks__grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    grid-template-rows: auto auto;\n    gap: 16px;\n  }\n  @media (max-width: 749px) {\n    .jp-picks__grid {\n      grid-template-columns: 1fr;\n    }\n  }\n  .jp-picks__item {\n    position: relative;\n    overflow: hidden;\n    background-color: #F0F0F0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    min-height: 320px;\n  }\n  .jp-picks__item:first-child {\n    grid-row: span 2;\n    min-height: 656px;\n  }\n  .jp-picks__item svg {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n  .jp-picks__overlay {\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    padding: 24px;\n    background: linear-gradient(transparent, rgba(0,0,0,0.7));\n    color: #FFFFFF;\n  }\n  .jp-picks__item-title {\n    font-size: 1.1rem;\n    font-weight: 700;\n    text-transform: uppercase;\n    margin: 0 0 4px 0;\n  }\n  .jp-picks__item-price {\n    font-size: 0.9rem;\n    color: #FFD600;\n    font-weight: 600;\n  }\n</style>\n<div class=\"jp-picks\">\n  <div class=\"jp-picks__header\">\n    <div class=\"jp-picks__tag\">Selección Especial</div>\n    <h2 class=\"jp-picks__title\">FAVORITOS DEL EDITOR</h2>\n  </div>\n  <div class=\"jp-picks__grid\">\n    <div class=\"jp-picks__item\">\n      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}\n      <div class=\"jp-picks__overlay\">\n        <div class=\"jp-picks__item-title\">Enterizo Deportivo</div>\n        <div class=\"jp-picks__item-price\">Desde $115.000</div>\n      </div>\n    </div>\n    <div class=\"jp-picks__item\">\n      {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}\n      <div class=\"jp-picks__overlay\">\n        <div class=\"jp-picks__item-title\">Vestido Deportivo</div>\n        <div class=\"jp-picks__item-price\">Desde $85.000</div>\n      </div>\n    </div>\n    <div class=\"jp-picks__item\">\n      {{ 'product-3' | placeholder_svg_tag: 'placeholder-svg' }}\n      <div class=\"jp-picks__overlay\">\n        <div class=\"jp-picks__item-title\">Conjunto Algodón</div>\n        <div class=\"jp-picks__item-price\">Desde $125.000</div>\n      </div>\n    </div>\n    <div class=\"jp-picks__item\">\n      {{ 'product-4' | placeholder_svg_tag: 'placeholder-svg' }}\n      <div class=\"jp-picks__overlay\">\n        <div class=\"jp-picks__item-title\">Conjunto Deportivo Crop Top + Short</div>\n        <div class=\"jp-picks__item-price\">Desde $95.000</div>\n      </div>\n    </div>\n  </div>\n</div>",
        "color_scheme": "scheme-1",
        "padding_top": 60,
        "padding_bottom": 60
      }
    },
    "sale_countdown": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  .jp-sale {\n    background-color: #0A0A0A;\n    color: #FFFFFF;\n    text-align: center;\n    padding: 70px 20px;\n  }\n  .jp-sale__tag {\n    font-size: 0.85rem;\n    text-transform: uppercase;\n    letter-spacing: 3px;\n    color: #999;\n    margin-bottom: 12px;\n  }\n  .jp-sale__title {\n    font-size: 2.4rem;\n    font-weight: 800;\n    text-transform: uppercase;\n    margin: 0 0 20px 0;\n  }\n  .jp-sale__discount {\n    font-size: 5rem;\n    font-weight: 900;\n    color: #FFD600;\n    line-height: 1;\n    margin-bottom: 30px;\n  }\n  @media (max-width: 749px) {\n    .jp-sale__discount {\n      font-size: 3.5rem;\n    }\n  }\n  .jp-sale__countdown {\n    display: flex;\n    justify-content: center;\n    gap: 24px;\n    margin-bottom: 40px;\n  }\n  .jp-sale__countdown-item {\n    text-align: center;\n  }\n  .jp-sale__countdown-number {\n    display: block;\n    font-size: 2.8rem;\n    font-weight: 800;\n    color: #FFFFFF;\n    line-height: 1;\n    min-width: 70px;\n    padding: 12px 16px;\n    border: 2px solid rgba(255,255,255,0.15);\n    border-radius: 8px;\n    margin-bottom: 8px;\n  }\n  .jp-sale__countdown-label {\n    font-size: 0.75rem;\n    text-transform: uppercase;\n    letter-spacing: 2px;\n    color: #999;\n  }\n  .jp-sale__btn {\n    display: inline-block;\n    background-color: #FFD600;\n    color: #0A0A0A;\n    padding: 16px 48px;\n    font-size: 0.95rem;\n    font-weight: 700;\n    text-transform: uppercase;\n    text-decoration: none;\n    letter-spacing: 1px;\n    transition: background-color 0.3s;\n  }\n  .jp-sale__btn:hover {\n    background-color: #e6c200;\n  }\n</style>\n<div class=\"jp-sale\">\n  <div class=\"jp-sale__tag\">Oferta Especial</div>\n  <h2 class=\"jp-sale__title\">REBAJAS DE TEMPORADA</h2>\n  <div class=\"jp-sale__discount\">70% OFF</div>\n  <div class=\"jp-sale__countdown\" id=\"jp-countdown\">\n    <div class=\"jp-sale__countdown-item\">\n      <span class=\"jp-sale__countdown-number\" id=\"jp-days\">00</span>\n      <span class=\"jp-sale__countdown-label\">Días</span>\n    </div>\n    <div class=\"jp-sale__countdown-item\">\n      <span class=\"jp-sale__countdown-number\" id=\"jp-hours\">00</span>\n      <span class=\"jp-sale__countdown-label\">Horas</span>\n    </div>\n    <div class=\"jp-sale__countdown-item\">\n      <span class=\"jp-sale__countdown-number\" id=\"jp-minutes\">00</span>\n      <span class=\"jp-sale__countdown-label\">Minutos</span>\n    </div>\n    <div class=\"jp-sale__countdown-item\">\n      <span class=\"jp-sale__countdown-number\" id=\"jp-seconds\">00</span>\n      <span class=\"jp-sale__countdown-label\">Segundos</span>\n    </div>\n  </div>\n  <a href=\"/collections/ofertas\" class=\"jp-sale__btn\">Comprar Ahora</a>\n</div>\n<script>\n  (function() {\n    var endDate = new Date('2026-12-31T23:59:59').getTime();\n    function updateCountdown() {\n      var now = new Date().getTime();\n      var diff = endDate - now;\n      if (diff <= 0) {\n        document.getElementById('jp-days').textContent = '00';\n        document.getElementById('jp-hours').textContent = '00';\n        document.getElementById('jp-minutes').textContent = '00';\n        document.getElementById('jp-seconds').textContent = '00';\n        return;\n      }\n      var days = Math.floor(diff / (1000 * 60 * 60 * 24));\n      var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));\n      var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));\n      var seconds = Math.floor((diff % (1000 * 60)) / 1000);\n      document.getElementById('jp-days').textContent = String(days).padStart(2, '0');\n      document.getElementById('jp-hours').textContent = String(hours).padStart(2, '0');\n      document.getElementById('jp-minutes').textContent = String(minutes).padStart(2, '0');\n      document.getElementById('jp-seconds').textContent = String(seconds).padStart(2, '0');\n    }\n    updateCountdown();\n    setInterval(updateCountdown, 1000);\n  })();\n</script>",
        "color_scheme": "scheme-4",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "instagram_gallery": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n  .jp-insta {\n    max-width: 1400px;\n    margin: 0 auto;\n    padding: 0 20px;\n  }\n  .jp-insta__header {\n    text-align: center;\n    margin-bottom: 40px;\n  }\n  .jp-insta__tag {\n    font-size: 0.85rem;\n    text-transform: uppercase;\n    letter-spacing: 3px;\n    color: #666;\n    margin-bottom: 12px;\n  }\n  .jp-insta__title {\n    font-size: 2.4rem;\n    font-weight: 800;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0;\n  }\n  .jp-insta__grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 16px;\n  }\n  @media (max-width: 749px) {\n    .jp-insta__grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n  .jp-insta__item {\n    aspect-ratio: 1;\n    background-color: #F0F0F0;\n    overflow: hidden;\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    transition: opacity 0.3s;\n  }\n  .jp-insta__item:hover {\n    opacity: 0.85;\n  }\n  .jp-insta__item > svg,\n  .jp-insta__item > .placeholder-svg {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n  .jp-insta__icon {\n    position: absolute;\n    top: 0;\n    left: 0;\n    opacity: 0;\n    transition: opacity 0.3s;\n    background: rgba(0,0,0,0.5);\n    width: 100%;\n    height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .jp-insta__item:hover .jp-insta__icon {\n    opacity: 1;\n  }\n  .jp-insta__icon svg {\n    width: 28px;\n    height: 28px;\n    fill: #FFFFFF;\n  }\n</style>\n<div class=\"jp-insta\">\n  <div class=\"jp-insta__header\">\n    <div class=\"jp-insta__tag\">@juanpisport</div>\n    <h2 class=\"jp-insta__title\">GALERÍA DE ESTILO</h2>\n  </div>\n  <div class=\"jp-insta__grid\">\n    <div class=\"jp-insta__item\">\n      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}\n      <div class=\"jp-insta__icon\"><svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0