    "hero_slideshow": {
      "type": "slideshow",
      "blocks": {
        "slide_1": {
          "type": "_slide",
          "settings": {
            "slide_background": true,
            "container": "page-width page-width--full",
            "height": "full",
            "media_type_1": "image",
            "inherit_color_scheme": false,
            "scheme_background": "#001E4A",
            "scheme_foreground_heading": "#FFFFFF",
            "scheme_foreground": "#FFFFFF",
            "scheme_primary": "#FFD600",
            "scheme_primary_hover": "#FFCA28",
            "scheme_border": "#001E4A",
            "scheme_shadow": "#000000"
          },
          "blocks": {
            "hero_tag": {
              "type": "text",
              "settings": {
                "text": "<p>Nueva Coleccion 2026</p>",
                "type_preset": "rte",
                "width": "fit-content"
              }
            },
            "hero_heading": {
              "type": "text",
              "settings": {
                "text": "<h1>ENTRENA CON ACTITUD</h1>",
                "type_preset": "rte",
                "highlight_text": true,
                "highlight_text_content": "ACTITUD",
                "highlight_text_type": "text",
                "highlight_text_color": "#FFD600",
                "width": "fit-content"
              }
            },
            "hero_subtitle": {
              "type": "text",
              "settings": {
                "text": "<p>Ropa deportiva femenina de alto rendimiento. Disenada para brindar soporte, comodidad y estilo en cada movimiento.</p>",
                "type_preset": "rte",
                "width": "fit-content"
              }
            },
            "hero_btn1": {
              "type": "button",
              "settings": {
                "label": "Ver Coleccion",
                "link": "shopify:\\/\\/collections\\/all",
                "style_class": "button",
                "button_style": "default"
              }
            },
            "hero_btn2": {
              "type": "button",
              "settings": {
                "label": "Ofertas Especiales",
                "link": "shopify:\\/\\/collections",
                "style_class": "button-secondary",
                "button_style": "outline"
              }
            }
          },
          "block_order": [
            "hero_tag",
            "hero_heading",
            "hero_subtitle",
            "hero_btn1",
            "hero_btn2"
          ]
        }
      },
      "block_order": [
        "slide_1"
      ],
      "settings": {
        "slideshow_type": "default",
        "section_width": "full-width",
        "slide_height": "large",
