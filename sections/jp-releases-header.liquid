<div class="jp-home">
<section class="section new-releases" id="new-releases">
  <div class="container">
    <div class="section-header">
      <p class="section-tag">{{ section.settings.tag }}</p>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "JP - Titulo Lanzamientos",
  "tag": "section",
  "class": "jp-releases-header-section",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Etiqueta",
      "default": "Lo Ultimo"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Titulo",
      "default": "NUEVOS <span class=\"highlight\">LANZAMIENTOS</span>"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Las ultimas prendas de alto rendimiento para tu entrenamiento."
    }
  ],
  "presets": [
    {
      "name": "JP - Titulo Lanzamientos"
    }
  ]
}
{% endschema %}
