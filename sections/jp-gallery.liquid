<div class="jp-home">
<section class="section gallery" id="gallery">
  <div class="container">
    <div class="section-header">
      <p class="section-tag">{{ section.settings.tag }}</p>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    </div>
  </div>
  <div class="gallery-grid">
    {%- for block in section.blocks -%}
      <div class="gallery-item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.image.alt }}
        {%- else -%}
          <div style="width:100%;height:100%;background:#F0EDED;display:flex;align-items:center;justify-content:center;color:#969696;">Agrega imagen</div>
        {%- endif -%}
        <div class="ig-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/></svg>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>
</div>

{% schema %}
{
  "name": "JP - Galeria Instagram",
  "tag": "section",
  "class": "jp-gallery-section",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Etiqueta",
      "default": "@juanpisport"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Titulo",
      "default": "GALERIA DE <span class=\"highlight\">ESTILO</span>"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Siguenos en Instagram para mas inspiracion."
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Imagen",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (opcional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "JP - Galeria Instagram",
      "blocks": [
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" }
      ]
    }
  ]
}
{% endschema %}
