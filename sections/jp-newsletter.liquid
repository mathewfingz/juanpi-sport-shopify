<div class="jp-home">
<section class="section newsletter">
  <div class="container">
    <div class="newsletter-inner">
      <p class="section-tag">{{ section.settings.tag }}</p>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {% form 'customer' %}
        <div class="newsletter-form">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required>
          <button type="submit">{{ section.settings.btn_label }}</button>
        </div>
      {% endform %}
    </div>
  </div>
</section>
</div>

{% schema %}
{
  "name": "JP - Newsletter",
  "tag": "section",
  "class": "jp-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Etiqueta",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "UNETE AL MOVIMIENTO"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Recibe ofertas exclusivas, lanzamientos y consejos de entrenamiento directo en tu correo."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder del input",
      "default": "Tu correo electronico"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Texto del boton",
      "default": "Suscribirme"
    }
  ],
  "presets": [
    {
      "name": "JP - Newsletter"
    }
  ]
}
{% endschema %}
